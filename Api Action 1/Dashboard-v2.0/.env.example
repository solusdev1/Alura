# ============================================
# SECURITY CONFIGURATION
# ============================================
# IMPORTANT: Rename this file to .env after filling it in
# NEVER commit the real .env file to Git
# ============================================

# ============================================
# MONGODB (REQUIRED)
# ============================================
# Paste your MongoDB Atlas connection string here
# Example: mongodb+srv://user:password@cluster.xxxxx.mongodb.net/
MONGODB_URI=mongodb+srv://seu-usuario:sua-senha@seu-cluster.mongodb.net/action1_inventory?retryWrites=true&w=majority

# Database name
MONGODB_DATABASE=action1_inventory

# ============================================
# ACTION1 API (REQUIRED)
# ============================================
# Credentials from https://app.action1.com/settings/api
ACTION1_CLIENT_ID=sua-client-id-aqui
ACTION1_CLIENT_SECRET=sua-client-secret-aqui

# ============================================
# ONLINE SYNC / VERCEL CRON
# ============================================
# Secret used by Vercel Cron when calling GET /api/sync
# Recommended: configure the same value in the Vercel project as CRON_SECRET
CRON_SECRET=gere-um-segredo-forte-aqui

# Optional secret for manual POST /api/sync
SYNC_SECRET=gere-outro-segredo-forte-aqui

# Optional: only for trusted internal frontend usage.
# Do not expose this in a public frontend without real authentication.
VITE_SYNC_SECRET=

# ============================================
# MICROSOFT 365 / MICROSOFT GRAPH
# ============================================
# App Registration credentials for sending the generated .docx by email
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# Fixed sender mailbox and fixed corporate recipient
M365_SENDER_EMAIL=
M365_RECIPIENT_EMAIL=

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Rename .env.example to .env
# 2. Fill in all required variables
# 3. NEVER commit the real .env file
# 4. In Vercel, configure these same variables in Project Settings
# 5. Vercel Cron sends GET requests to /api/sync in UTC
#    Current schedules: 14:00 UTC and 18:00 UTC
#    Equivalent to 11:00 and 15:00 in America/Sao_Paulo
# 6. Set CRON_SECRET in Vercel to protect scheduled execution
# 7. For Microsoft 365 email sending, create an Azure App Registration
# 8. Grant Microsoft Graph application permission to send email and give admin consent
# 9. Ensure M365_SENDER_EMAIL is a real mailbox that the app can use
# ============================================
